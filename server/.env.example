# ─────────────────────────────────────────────
#  Twitch Application — https://dev.twitch.tv/console
# ─────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# URI de redirection (doit correspondre à celle enregistrée dans la console Twitch)
TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=

# ─────────────────────────────────────────────
#  Tokens (remplis automatiquement par : npm run get-token)
# ─────────────────────────────────────────────
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ─────────────────────────────────────────────
#  Liens communauté
# ─────────────────────────────────────────────
DISCORD_URL=https://discord.gg/xxxxxxx
